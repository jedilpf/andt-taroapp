{
  "compilerOptions": {
    "target": "ES2015",
    "lib": ["esnext", "dom", "dom.iterable"],
    "module": "ESNext",
    "jsx": "react-jsx",
    "jsxImportSource": "@tarojs/taro",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["./src", "./types"],
  "exclude": ["node_modules"]
}
